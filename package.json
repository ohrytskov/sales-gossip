    "eslint": "8.57.0",
    "eslint-config-next": "15.5.10",
    "eslint-config-prettier": "^8.8.0",
    "jest": "^30.0.0",
    "postcss": "^8.4.26",
    "puppeteer-core": "^24.35.0",
    "sass": "^1.62.0",
    "tailwindcss": "^3.3.3",
    "typescript": "^5.0.4",
    "wrangler": "^4.65.0"
